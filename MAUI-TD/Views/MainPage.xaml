<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MAUI_TD.Views.MainPage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
            Text="Morpion"
            FontSize="40"
            HorizontalOptions="Center"/>

        <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*,*" RowSpacing="5" ColumnSpacing="5">

            <Button Grid.Row="0" Grid.Column="0" Text="{Binding B1}" Command="{Binding PlayCommand}" CommandParameter="1"/>
            <Button Grid.Row="0" Grid.Column="1" Text="{Binding B2}" Command="{Binding PlayCommand}" CommandParameter="2"/>
            <Button Grid.Row="0" Grid.Column="2" Text="{Binding B3}" Command="{Binding PlayCommand}" CommandParameter="3"/>

            <Button Grid.Row="1" Grid.Column="0" Text="{Binding B4}" Command="{Binding PlayCommand}" CommandParameter="4"/>
            <Button Grid.Row="1" Grid.Column="1" Text="{Binding B5}" Command="{Binding PlayCommand}" CommandParameter="5"/>
            <Button Grid.Row="1" Grid.Column="2" Text="{Binding B6}" Command="{Binding PlayCommand}" CommandParameter="6"/>

            <Button Grid.Row="2" Grid.Column="0" Text="{Binding B7}" Command="{Binding PlayCommand}" CommandParameter="7"/>
            <Button Grid.Row="2" Grid.Column="1" Text="{Binding B8}" Command="{Binding PlayCommand}" CommandParameter="8"/>
            <Button Grid.Row="2" Grid.Column="2" Text="{Binding B9}" Command="{Binding PlayCommand}" CommandParameter="9"/>

        </Grid>

    </VerticalStackLayout>

</ContentPage>