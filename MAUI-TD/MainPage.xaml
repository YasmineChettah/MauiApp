<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_TD.MainPage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label
            Text="Morpion"
            FontSize="40"
            HorizontalOptions="Center"/>

        <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*,*" RowSpacing="5" ColumnSpacing="5">

            <Button x:Name="B1" Grid.Row="0" Grid.Column="0" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B2" Grid.Row="0" Grid.Column="1" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B3" Grid.Row="0" Grid.Column="2" Clicked="OnCellClicked" FontSize="40"/>

            <Button x:Name="B4" Grid.Row="1" Grid.Column="0" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B5" Grid.Row="1" Grid.Column="1" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B6" Grid.Row="1" Grid.Column="2" Clicked="OnCellClicked" FontSize="40"/>

            <Button x:Name="B7" Grid.Row="2" Grid.Column="0" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B8" Grid.Row="2" Grid.Column="1" Clicked="OnCellClicked" FontSize="40"/>
            <Button x:Name="B9" Grid.Row="2" Grid.Column="2" Clicked="OnCellClicked" FontSize="40"/>
           
        </Grid>

    </VerticalStackLayout>

</ContentPage>